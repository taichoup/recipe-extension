{
  "manifest_version": 3,
  "name": "Recipe Importer",
  "version": "1.0",
  "description": "Save recipes to Obsidian and add ingredients to Bring!",
  "browser_specific_settings": {
    "gecko": {
      "id": "recipe-importer@manu",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["activeTab", "scripting", "nativeMessaging"],
  "host_permissions": ["https://api.getbring.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Recipe Importer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
